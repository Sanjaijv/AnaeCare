# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=anaecare
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/anaecare

# Security
JWT_SECRET=supersecretjwtkey_replace_in_production
JWT_REFRESH_SECRET=supersecretrefreshkey_replace_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# pgAdmin
PGADMIN_EMAIL=admin@anaecare.com
PGADMIN_PASSWORD=admin

# Storage (Local for now)
STORAGE_TYPE=local
STORAGE_BASE_PATH=./uploads
API_BASE_URL=http://localhost:8000
